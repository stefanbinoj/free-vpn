# Active cloud provider. One of: aws | azure | gcp | do.
CLOUD_PROVIDER=aws

# Cloud credentials. Only the block matching CLOUD_PROVIDER is used.

# AWS
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Azure
# ARM_SUBSCRIPTION_ID=
# ARM_CLIENT_ID=
# ARM_CLIENT_SECRET=
# ARM_TENANT_ID=

# GCP
# GOOGLE_CREDENTIALS=/absolute/path/to/service-account.json
# GOOGLE_PROJECT=your-gcp-project-id

# DigitalOcean
# DIGITALOCEAN_TOKEN=your-do-api-token
